# ─── AVAAT Design — Environment Variables Reference ───────────────────────────
# Copy this file to .env.local for local dev, or set in Vercel / your host.

# ─── Supabase (REQUIRED) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Site URL (REQUIRED) ──────────────────────────────────────────────────────
# Used for SEO metadata base, sitemaps, and OG images.
NEXT_PUBLIC_SITE_URL=https://avaat.design

# ─── Google Analytics 4 (optional) ───────────────────────────────────────────
# Leave blank to disable tracking. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ─── On-demand ISR Revalidation (REQUIRED for CMS webhooks) ──────────────────
# Set a strong random secret. Call POST /api/revalidate?secret=<value> to purge cache.
REVALIDATE_SECRET=your-secure-secret-here
